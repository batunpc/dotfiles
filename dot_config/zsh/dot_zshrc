# ─── Functions: utilities (preserved + extended) ─────────────────────────────
hr() { printf '%*s\n' "${COLUMNS:-$(tput cols)}" '' | tr ' ' '='; }

timezsh() {
  for i in {1..10}; do /usr/bin/time $SHELL -i -c exit; done
}

# Make a dir and cd into it
mkcd() { mkdir -p "$1" && cd "$1"; }

# Extract any archive
extract() {
  [[ -f "$1" ]] || { echo "❌ '$1' is not a valid file"; return 1; }
  case "$1" in
    *.tar.bz2)  tar xjf "$1"   ;;  *.tar.gz)   tar xzf "$1"   ;;
    *.tar.xz)   tar xJf "$1"   ;;  *.bz2)      bunzip2 "$1"   ;;
    *.rar)      unrar x "$1"   ;;  *.gz)       gunzip "$1"    ;;
    *.tar)      tar xf "$1"    ;;  *.tbz2)     tar xjf "$1"   ;;
    *.tgz)      tar xzf "$1"   ;;  *.zip)      unzip "$1"     ;;
    *.Z)        uncompress "$1";;  *.7z)       7z x "$1"      ;;
    *)          echo "❌ '$1': unknown archive format"; return 1 ;;
  esac
}

# Find a process by name
psg() { ps aux | grep -i "$1" | grep -v grep; }

# ─── Functions: macOS ────────────────────────────────────────────────────────
# 💀 Kill Spotlight if enabled
disable_spotlight_if_active() {
  echo "🔍 Checking Spotlight status..."
  local sp_status=$(sudo mdutil -s / | grep -E "Indexing.*(enabled|active)")
  if [[ -n "$sp_status" ]]; then
    echo "⚠️  Spotlight is still active. Disabling..."
    sudo mdutil -a -i off
    sudo launchctl bootout system /System/Library/LaunchDaemons/com.apple.metadata.mds.plist 2>/dev/null || echo "ℹ️ Could not fully unload Spotlight daemon (normal on SIP-enabled Macs)."
    sudo pkill mds
    sudo pkill mdworker
    sudo pkill mdworker_shared
    echo "✅ Spotlight has been disabled."
  else
    echo "✅ Spotlight is already disabled. Nothing to do."
  fi
}

# ─── Lazy loaders (don't slow startup) ───────────────────────────────────────
# NVM
export NVM_DIR="$HOME/.nvm"
if [ -s "$BREW_PREFIX/opt/nvm/nvm.sh" ]; then
  nvm() {
    unset -f nvm node npm npx 2>/dev/null
    source "$BREW_PREFIX/opt/nvm/nvm.sh"
    [ -f "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \
      source "$BREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"
    nvm "$@"
  }
  # Also lazy-load on first node/npm/npx call
  node() { unset -f node npm npx nvm 2>/dev/null; source "$BREW_PREFIX/opt/nvm/nvm.sh"; node "$@"; }
  npm()  { unset -f node npm npx nvm 2>/dev/null; source "$BREW_PREFIX/opt/nvm/nvm.sh"; npm "$@"; }
  npx()  { unset -f node npm npx nvm 2>/dev/null; source "$BREW_PREFIX/opt/nvm/nvm.sh"; npx "$@"; }
fi

# Conda
conda() {
  unset -f conda
  for _c in "$HOME/anaconda3" "$HOME/miniconda3" "$HOME/miniforge3" "$BREW_PREFIX/Caskroom/miniconda/base"; do
    [ -f "$_c/etc/profile.d/conda.sh" ] && { source "$_c/etc/profile.d/conda.sh"; break; }
  done
  unset _c
  conda "$@"
}

# ─── Eval cache: zoxide / direnv / atuin / mise ──────────────────────────────
# These tools' `init zsh` output is dynamic but stable.  Cache it for a week
# to skip ~150-300ms of fork/eval cost on every shell start.
ZSHEVAL_CACHE=~/.cache/zsh-eval-cache.zsh
ZSHEVAL_MAX_AGE=604800
_rebuild_eval_cache() {
  mkdir -p ~/.cache
  {
    command -v zoxide       &>/dev/null && zoxide init zsh
    command -v direnv       &>/dev/null && direnv hook zsh
    command -v atuin        &>/dev/null && atuin init zsh --disable-up-arrow
    command -v mise         &>/dev/null && mise activate zsh
    command -v carapace     &>/dev/null && carapace _carapace zsh
    command -v pay-respects &>/dev/null && pay-respects zsh --alias f
  } > "$ZSHEVAL_CACHE" 2>/dev/null
}
if [[ -f $ZSHEVAL_CACHE ]]; then
  _age=$(( $(date +%s) - $(stat -f %m $ZSHEVAL_CACHE 2>/dev/null || echo 0) ))
  if (( _age < ZSHEVAL_MAX_AGE )); then
    source $ZSHEVAL_CACHE
  else
    _rebuild_eval_cache
    [[ -s $ZSHEVAL_CACHE ]] && source $ZSHEVAL_CACHE
  fi
else
  _rebuild_eval_cache
  [[ -s $ZSHEVAL_CACHE ]] && source $ZSHEVAL_CACHE
fi
zsh-eval-cache-rebuild() { _rebuild_eval_cache && source $ZSHEVAL_CACHE && echo "✅ Eval cache rebuilt"; }
unset ZSHEVAL_CACHE ZSHEVAL_MAX_AGE

# zoxide-cd: `cd` falls back to `z` for fuzzy navigation
unalias cd 2>/dev/null
cd() {
  if (( $# == 0 )); then builtin cd
  elif [[ -d "$1" ]]; then builtin cd "$1"
  else z "$1" 2>/dev/null || builtin cd "$1"
  fi
}

# ─── Modular config ──────────────────────────────────────────────────────────
[ -f ~/.config/zsh/.zshrc.exports.sh ]   && source ~/.config/zsh/.zshrc.exports.sh
[ -f ~/.config/zsh/.zshrc.aliases.sh ]   && source ~/.config/zsh/.zshrc.aliases.sh
[ -f ~/.config/zsh/.zshrc.functions.sh ] && source ~/.config/zsh/.zshrc.functions.sh

# ─── Dart CLI completion ─────────────────────────────────────────────────────
[[ -f "$HOME/.dart-cli-completion/zsh-config.zsh" ]] && . "$HOME/.dart-cli-completion/zsh-config.zsh" || true

# ─── Machine-local overrides + secrets (never committed) ─────────────────────
# Put machine-specific env, tokens, and webhooks in ~/.config/zsh/local.zsh.
# That file is gitignored / chezmoi-ignored, so it never reaches the public repo.
[ -f ~/.config/zsh/local.zsh ] && source ~/.config/zsh/local.zsh

# ─── fzf-git: Ctrl-G pickers for branches/hashes/stashes/etc. ────────────────
# https://github.com/junegunn/fzf-git.sh
[ -f ~/.config/fzf-git.sh ] && source ~/.config/fzf-git.sh

# ─── onefetch on cd into a git repo (opt-in: export ONEFETCH_ON_CD=true) ──────
# Off by default to keep cd snappy. The `repo` alias runs it on demand anytime.
autoload -Uz add-zsh-hook
_onefetch_on_cd() {
  [[ "${ONEFETCH_ON_CD:-false}" == true ]] || return
  command -v onefetch &>/dev/null || return
  local top; top=$(git rev-parse --show-toplevel 2>/dev/null) || return
  [[ "$top" == "$PWD" && "$top" != "$_ONEFETCH_LAST" ]] || return
  _ONEFETCH_LAST="$top"; onefetch 2>/dev/null
}
add-zsh-hook chpwd _onefetch_on_cd

# ─── Compile sourced files to bytecode (.zwc) for faster startup ──────────────
for _f in ~/.config/zsh/.zshrc.exports.sh ~/.config/zsh/.zshrc.aliases.sh \
          ~/.config/zsh/.zshrc.functions.sh ~/.config/zsh/.p10k.zsh; do
  [[ -f "$_f" && ( ! -f "$_f.zwc" || "$_f" -nt "$_f.zwc" ) ]] && zcompile -R -- "$_f.zwc" "$_f" 2>/dev/null
done
unset _f

# ─── Greeter (set TERMINAL_INTRO=off to silence) ─────────────────────────────
# Modes: fortune | fortunecow | fortunefast | fetch | fetchfx | minimal | off
#   fortune     — short fortune piped through lolcat (rainbow, requires lolcat)
#   fortunecow  — short fortune in a cowsay bubble, piped through lolcat
#   fortunefast — plain monochrome fortune (no lolcat)
#   fetch       — fastfetch / neofetch system info
#   minimal     — single-line "ready" banner
#   off         — silent
TERMINAL_INTRO="${TERMINAL_INTRO:-fortune}"
if [[ -o interactive ]] && [[ -t 0 ]]; then
  case "$TERMINAL_INTRO" in
    fortune)     command -v fortune  &>/dev/null && (clear 2>/dev/null; fortune -s 2>/dev/null | (command -v lolcat &>/dev/null && lolcat || cat) 2>/dev/null) ;;
    fortunecow)  command -v fortune  &>/dev/null && command -v cowsay &>/dev/null && (clear 2>/dev/null; fortune -s 2>/dev/null | cowsay -f tux 2>/dev/null | (command -v lolcat &>/dev/null && lolcat || cat) 2>/dev/null) ;;
    fortunefast) command -v fortune  &>/dev/null && (clear 2>/dev/null; fortune -s 2>/dev/null) ;;
    fetch)       command -v fastfetch &>/dev/null && (clear 2>/dev/null; fastfetch) || command -v neofetch &>/dev/null && (clear 2>/dev/null; neofetch) ;;
    fetchfx)     command -v fastfetch &>/dev/null && command -v tte &>/dev/null && (clear 2>/dev/null; fastfetch -l none 2>/dev/null | tte slide 2>/dev/null) || { command -v fastfetch &>/dev/null && (clear 2>/dev/null; fastfetch); } ;;
    minimal)     clear 2>/dev/null; print -P '%F{cyan}╭─────────────────────────────────────╮%f\n%F{cyan}╰%f %F{green}ready%f' ;;
    off)         ;;
  esac
fi
