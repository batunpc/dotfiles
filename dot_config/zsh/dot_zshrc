# ─── ~/.zshrc ────────────────────────────────────────────────────────────────
# Fast, modern zsh.  Real file: ~/.config/zsh/.zshrc  (symlinked from ~/.zshrc)
# Backup of previous file at ~/.zshrc.bak.*
# Reload after edits with:  exec zsh
# Measure startup with:     timezsh

# ─── Prompt selection ────────────────────────────────────────────────────────
# Which prompt to load: p10k (default) or minimal. Flip with: prompt minimal
ZSH_PROMPT="$(cat ${ZDOTDIR:-$HOME/.config/zsh}/.prompt 2>/dev/null || echo p10k)"

# ─── Powerlevel10k instant prompt (MUST stay near the top; p10k only) ────────
# Renders the prompt immediately on shell start; the real prompt fills in after.
if [[ "$ZSH_PROMPT" == p10k && -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ─── Homebrew (must be early so later code finds brew-installed binaries) ────
# Portable across Apple Silicon (/opt/homebrew) and Intel (/usr/local).
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
export BREW_PREFIX="${HOMEBREW_PREFIX:-$(brew --prefix 2>/dev/null)}"

# ─── PATH ────────────────────────────────────────────────────────────────────
# Add each dir only if it exists, so this stays portable across machines.
typeset -U path PATH                                # auto-dedupe entries
_add=()
for _p in \
  $HOME/.local/bin \
  $HOME/.bun/bin \
  $HOME/.yarn/bin \
  $HOME/.config/yarn/global/node_modules/.bin \
  $HOME/.cargo/bin \
  $HOME/documents/flutter/bin \
  $HOME/.maestro/bin \
  $HOME/.lmstudio/bin \
  $HOME/.dotnet/tools \
  $HOME/Library/Android/sdk/platform-tools \
  $BREW_PREFIX/opt/openssl@1.1/bin \
  $BREW_PREFIX/opt/qt@5/bin \
  /Library/Frameworks/Python.framework/Versions/3.12/bin
do
  [[ -d "$_p" ]] && _add+=("$_p")
done
path=($_add $path)
unset _p _add
export PATH

export LANG=en_US.UTF-8
export BUN_INSTALL="$HOME/.bun"
# JAVA_HOME: prefer a pinned JDK if present, else fall back to system java_home.
if [[ -d "$HOME/Library/Java/JavaVirtualMachines/openjdk-17.0.2/Contents/Home" ]]; then
  export JAVA_HOME="$HOME/Library/Java/JavaVirtualMachines/openjdk-17.0.2/Contents/Home"
elif [[ -x /usr/libexec/java_home ]]; then
  export JAVA_HOME="$(/usr/libexec/java_home 2>/dev/null)"
fi
[[ -n "$JAVA_HOME" && -d "$JAVA_HOME/bin" ]] && path=("$JAVA_HOME/bin" $path) && export PATH

# ─── History ─────────────────────────────────────────────────────────────────
HISTFILE=$HOME/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS \
       HIST_VERIFY SHARE_HISTORY INC_APPEND_HISTORY EXTENDED_HISTORY

# ─── Shell options ───────────────────────────────────────────────────────────
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT
setopt INTERACTIVE_COMMENTS PROMPT_SUBST GLOB_DOTS NO_BEEP
setopt CORRECT NUMERIC_GLOB_SORT

# ─── Completions (cached, refreshes once per day) ────────────────────────────
# -i: skip any group/other-writable fpath dirs instead of stopping with a
# "[y]/[n]?" prompt that hangs the shell (common with Homebrew completion dirs).
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit -i                                       # ≥24h old → full rebuild, ignore insecure
else
  compinit -C -i                                    # fresh → use cache, skip security check
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' group-name ''

# ─── Prompt ──────────────────────────────────────────────────────────────────
# p10k (default) or a minimal pure-zsh prompt. Switch with `prompt <name>`.
if [[ "$ZSH_PROMPT" == minimal ]]; then
  source ~/.config/zsh/prompts/minimal.zsh
else
  # Powerlevel10k: brew install preferred, manual clone fallback. `p10k configure` to tweak.
  if [[ -r "$BREW_PREFIX/share/powerlevel10k/powerlevel10k.zsh-theme" ]]; then
    source "$BREW_PREFIX/share/powerlevel10k/powerlevel10k.zsh-theme"
  elif [[ -r "$HOME/.config/powerlevel10k/powerlevel10k.zsh-theme" ]]; then
    source "$HOME/.config/powerlevel10k/powerlevel10k.zsh-theme"
  fi
  # random left-edge Nerd Font glyph + color, changes every session (used by .p10k.zsh)
  #     curated to glyphs that render at a uniform size: bug paw rocket star heart fire ninja bomb magic rebel
  _codes=(f188 f1b0 f135 f005 f004 f06d f21b f1e2 f0d0 f1d0)
  _cols=(39 75 111 212 213 141 183 114 84 215 222 80 209 203 220)
  P10K_OS_ICON=$(print -n "\u${_codes[RANDOM % $#_codes + 1]}")
  P10K_OS_COLOR=${_cols[RANDOM % $#_cols + 1]}
  unset _codes _cols
  [ -f ~/.config/zsh/.p10k.zsh ] && source ~/.config/zsh/.p10k.zsh
fi

# prompt switcher: `prompt minimal` or `prompt p10k` (persists per machine, reloads)
prompt() {
  local choice="$1" file="${ZDOTDIR:-$HOME/.config/zsh}/.prompt"
  case "$choice" in
    p10k|minimal) print -r -- "$choice" > "$file"; print -P "%F{green}→%f prompt: $choice"; exec zsh ;;
    "")  print -P "current: %F{cyan}$ZSH_PROMPT%f    usage: prompt {p10k|minimal}" ;;
    *)   print -P "%F{red}unknown prompt:%f $choice    (options: p10k, minimal)" ;;
  esac
}

# ─── LS_COLORS ───────────────────────────────────────────────────────────────
[ -f ~/.config/.LS_COLORS/lscolors.sh ] && source ~/.config/.LS_COLORS/lscolors.sh

# ─── FZF: fuzzy finder + Catppuccin-ish theme ────────────────────────────────
if [ -f ~/.fzf.zsh ]; then
  source ~/.fzf.zsh
elif [ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]; then
  source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
  source /opt/homebrew/opt/fzf/shell/completion.zsh
fi
export FZF_DEFAULT_OPTS="
  --height 50% --layout=reverse --border=rounded --info=inline
  --color=bg+:#313244,bg:-1,spinner:#f5c2e7,hl:#f38ba8
  --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc
  --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"
export FZF_CTRL_T_OPTS="--preview 'bat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --color=always --icons {} 2>/dev/null'"
export FZF_DEFAULT_COMMAND='fd --type f --strict-mtime --hidden --follow --exclude .git 2>/dev/null || find . -type f'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# ─── fzf-tab: replace tab completion menu with fzf ───────────────────────────
[ -f ~/.config/zsh/fzf-tab/fzf-tab.plugin.zsh ] && source ~/.config/zsh/fzf-tab/fzf-tab.plugin.zsh
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --tree --level=2 --color=always --icons $realpath 2>/dev/null'
zstyle ':fzf-tab:complete:*:*' fzf-preview 'bat --style=numbers --color=always --line-range :200 $realpath 2>/dev/null || eza --color=always --icons $realpath 2>/dev/null'
zstyle ':fzf-tab:*' switch-group ',' '.'

# ─── Plugins ─────────────────────────────────────────────────────────────────
# zmv: pattern-based mass rename (e.g. zmv '(*).jpeg' '$1.jpg')
autoload -Uz zmv

# zsh-abbr: fish-style abbreviations that expand inline as you type.
# Abbreviations live in ~/.config/zsh-abbr/user-abbreviations (version-controlled).
# https://github.com/olets/zsh-abbr
for _abbr in \
  "$BREW_PREFIX/share/zsh-abbr/zsh-abbr.zsh" \
  "$BREW_PREFIX/opt/zsh-abbr/share/zsh-abbr/zsh-abbr.zsh"; do
  [[ -r "$_abbr" ]] && { source "$_abbr"; break; }
done
unset _abbr

# carapace: argument-aware completions for 1000+ CLIs, bridged from other shells.
# The `carapace _carapace zsh` init itself lives in the eval cache below (cheap).
# https://carapace.sh
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'

# Autosuggestions: greyed-out completion of history as you type (→ to accept)
if [[ -r "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
elif [[ -r "$HOME/.config/zsh/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "$HOME/.config/zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# fast-syntax-highlighting must be sourced LAST among plugin sources
if [[ -r "$BREW_PREFIX/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]]; then
  source "$BREW_PREFIX/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
fi
# Color overrides (must run AFTER the plugin loads its theme).
# `correct-subtle` is the key fast-syntax-highlighting's git chroma uses for
# branch/ref arguments (e.g. `main` in `git checkout main`). Default is a blue
# background block (bg=blue); switch it to soft blue text instead.
# Token reference: https://github.com/zdharma-continuum/fast-syntax-highlighting
typeset -gA FAST_HIGHLIGHT_STYLES
FAST_HIGHLIGHT_STYLES[correct-subtle]='fg=blue'

# ─── Key bindings ────────────────────────────────────────────────────────────
bindkey '^R'   fzf-history-widget                       # ctrl+R fzf-over-history
bindkey '^[[1;5D' backward-word                         # ctrl+left
bindkey '^[[1;5C' forward-word                          # ctrl+right
bindkey '^[w'  backward-kill-word                       # alt+w
bindkey '^[.'  insert-last-word                         # alt+. last arg of previous cmd

